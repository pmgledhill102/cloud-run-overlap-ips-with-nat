        <!-- ==================== KEY INSIGHT ==================== -->
        <mxCell id="insight" value="Key Insight: VPC Connector eliminates the Hybrid NAT step from Flow A.&lt;br&gt;Cloud Run traffic exits through connector VMs with unique 10.10.x.0/28 IPs that are directly routable via BGP — no address translation needed.&lt;br&gt;Flow B is identical to the Direct VPC Egress approach (ILB + serverless NEG)." style="text;html=1;fontSize=11;fontColor=#3C4043;align=left;verticalAlign=top;fillColor=#E8F5E9;rounded=1;strokeColor=#2E7D32;spacingLeft=10;spacingRight=10;spacingTop=8;spacingBottom=8;whiteSpace=wrap;" vertex="1" parent="1">
